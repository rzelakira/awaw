local function teleportToTradeZone()
    local island = getIslandModel()
    if not island then
        Notify("Auto Trade Error", "Island not found!", 3)
        return false
    end

    local env = island:FindFirstChild("ENV")
    if env then env = env:FindFirstChild("TradeZone") end
    if not env then
        Notify("Auto Trade Error", "TradeZone not found!", 3)
        return false
    end

    local touch = env:FindFirstChild("Touch")

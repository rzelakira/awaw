    State.PlacingActive = false
end

local function autoCollectPets()
    if State.CollectingActive then return end
    if not fireproximityprompt then
        Notify("Auto Collect", "Executor tidak support fireproximityprompt", 4)
        return
    end

    local petsWorkspace = workspace:FindFirstChild("Pets")
    if not petsWorkspace then
        Notify("Auto Collect", "Pets folder not found", 3)
        return
    end
    local ppart = workspace:FindFirstChild("PPart")
    local prompt = ppart and ppart:FindFirstChildWhichIsA("ProximityPrompt")
    if not prompt then
        Notify("Auto Collect", "PPart prompt not found", 3)
        return
    end
    if prompt.ActionText ~= "Recall" then
        Notify("Auto Collect", "Equip Hammer (hotbar slot 1) dulu", 4)
        return
    end

    local filter    = _G.BuildAZooSettings.Collect.Filter
    local threshold = tonumber(_G.BuildAZooSettings.Collect.Threshold) or 0

    local targets = {}
    for _, pet in ipairs(petsWorkspace:GetChildren()) do
        if pet:GetAttribute("UserId") == State.LocalPlayer.UserId then
            local ps = pet:GetAttribute("ProduceSpeed") or 0
            local g  = pet:GetAttribute("GridCenterPos")
            local pass = (filter == "Above" and ps >= threshold) or (filter == "Below" and ps <= threshold)
            if pass and g then
                table.insert(targets, { uid = pet.Name, ps = ps, pos = g })
            end
        end
    end

    if #targets == 0 then
        Notify("Auto Collect", "Tidak ada pet yang cocok filter", 3)
        return
    end
    table.sort(targets, function(a, b) return a.ps < b.ps end)

    State.CollectingActive = true
    State.CollectThread = task.spawn(function()
        local char = State.LocalPlayer.Character or State.LocalPlayer.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local origCF = hrp.CFrame
        local collected = 0

        for _, t in ipairs(targets) do
            if not State.CollectingActive then break end
            if petsWorkspace:FindFirstChild(t.uid) then
                hrp.Anchored = false
                hrp.CFrame = CFrame.new(t.pos.X, t.pos.Y + 3, t.pos.Z)
                task.wait(0.35)
                if prompt.ActionText == "Recall" then
                    prompt.Enabled = true
                    fireproximityprompt(prompt)
                    task.wait(0.55)
                    if not petsWorkspace:FindFirstChild(t.uid) then
                        collected = collected + 1
                    end
                end
            end
        end

        pcall(function()
            hrp.Anchored = false
            hrp.CFrame = origCF
        end)
        State.CollectingActive = false
        State.CollectThread = nil
        Notify("Auto Collect", "Selesai - " .. collected .. " pet di-recall", 4)
    end)
end

local function stopAutoCollect()
    State.CollectingActive = false
end


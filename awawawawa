local function findEggToBuy(eggTypes, mutations)
    if State.IslandName == "" then return nil end

    local eggsRoot = ReplicatedStorage:FindFirstChild("Eggs")
    if not eggsRoot then return nil end

    local islandEggs = eggsRoot:FindFirstChild(State.IslandName)
    if not islandEggs then return nil end

    local wantedTypes = {}
    for _, name in ipairs(eggTypes) do
        table.insert(wantedTypes, State.EggsIDs[name] or name)
    end

    local foundUid, foundType, foundMutation = nil, "Unknown", "None"
    for _, egg in ipairs(islandEggs:GetChildren()) do
        local t = egg:GetAttribute("T")
        local m = egg:GetAttribute("M") or "None"
        if tableContains(wantedTypes, t) then
            if not mutations or #mutations == 0 then
                foundUid, foundType, foundMutation = egg.Name, t, m
                break
            elseif tableContains(mutations, m) then
                foundUid, foundType, foundMutation = egg.Name, t, m
                break
            elseif tableContains(mutations, "None") and m == "None" then
                foundUid, foundType, foundMutation = egg.Name, t, "None"
                break
            end
        end
    end

    if foundUid then
        State.EggName   = foundType
        State.EggMutate = foundMutation
    end
    return foundUid
end


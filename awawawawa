        Notify("Auto Trade Error", "Touch part not found!", 3)
        return false
    end

    local rootPart = (State.LocalPlayer.Character or State.LocalPlayer.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    rootPart.CFrame = touch.CFrame + Vector3.new(0, 3, 0)

    local startTime = tick()
    local timeout   = 5
    while (rootPart.Position - touch.Position).Magnitude > 10 and tick() - startTime < timeout do

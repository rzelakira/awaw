local function runAutoClimb()
    local laneX, laneZ     = -170.048569, 166.167160
    local centerX, centerZ = -170.768677, 172.301239
    local targetHeight     = 11000
    local speed            = 2600
    local holdAfterClaim   = 3.0

    local climbRemote = Remote("ClimbSyncRE")
    local timeValue   = ReplicatedStorage:WaitForChild("Time")

    local area = workspace:WaitForChild("ClimbJumpArea")
    local farm = area:WaitForChild("Farm")
    local baseY   = farm.Position.Y + farm.Size.Y * 0.5
    local targetY = baseY + targetHeight + 5

    local milestones = {
        { id = "L1", h = 600 },
        { id = "L2", h = 2000 },
        { id = "L3", h = 5000 },
        { id = "L4", h = 11000 },
    }

    local function salt()
        local s = timeValue:GetAttribute("s") or 0
        return bit32.bxor(State.LocalPlayer.UserId, s, timeValue.Value)
    end

    local function cfAt(y)
        return CFrame.lookAt(Vector3.new(laneX, y, laneZ), Vector3.new(centerX, y, centerZ))
    end

    local character = State.LocalPlayer.Character or State.LocalPlayer.CharacterAdded:Wait()
    local humanoid  = character:WaitForChild("Humanoid")
    local rootPart  = character:WaitForChild("HumanoidRootPart")

    local oldAutoRotate     = humanoid.AutoRotate
    local oldPlatformStand  = humanoid.PlatformStand

    State.LocalPlayer:SetAttribute("AutoClimb", false)
    humanoid.AutoRotate    = false
    humanoid.PlatformStand = true
    rootPart.Anchored = true
    rootPart.AssemblyLinearVelocity  = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero

    local reached = {}
    local function fireReachAndClaim(heightNow)
        for _, m in ipairs(milestones) do
            if not reached[m.id] and heightNow >= m.h then
                reached[m.id] = true
                climbRemote:FireServer("CJReach", m.id, salt())
                task.wait(0.1)
                for _ = 1, 3 do
                    climbRemote:FireServer("CJClaim", m.id, salt())
                    task.wait(0.08)
                end
            end
        end
    end

    local function claimAll()
        for _, m in ipairs(milestones) do
            climbRemote:FireServer("CJReach", m.id, salt())
            task.wait(0.05)
            for _ = 1, 2 do
                climbRemote:FireServer("CJClaim", m.id, salt())
                task.wait(0.05)
            end
        end
    end

    local y = math.max(rootPart.Position.Y, baseY + 22)
    State.ClimbHeartbeat = RunService.Heartbeat:Connect(function()
        if not State.ClimbActive or not rootPart.Parent then return end
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Climbing) end)
        State.LocalPlayer:SetAttribute("Climbing", true)
        State.LocalPlayer:SetAttribute("IsInJumpClimb", true)
        State.LocalPlayer:SetAttribute("ClimbHudHide", true)
        State.LocalPlayer:SetAttribute("ClimbDeepY", math.max(0, y - baseY))
        rootPart.CFrame = cfAt(y)
        rootPart.AssemblyLinearVelocity  = Vector3.zero
        rootPart.AssemblyAngularVelocity = Vector3.zero
    end)

    while State.ClimbActive and y < targetY and rootPart.Parent do
        local dt = RunService.Heartbeat:Wait()
        y = math.min(targetY, y + speed * dt)
        fireReachAndClaim(y - baseY)
    end

    if State.ClimbActive then
        task.wait(0.25)
        claimAll()
        task.wait(holdAfterClaim)
        claimAll()
    end

    State.ClimbActive = false
    if State.ClimbHeartbeat then
        State.ClimbHeartbeat:Disconnect()
        State.ClimbHeartbeat = nil
    end

    State.LocalPlayer:SetAttribute("ClimbHudHide", false)
    humanoid.AutoRotate    = oldAutoRotate
    humanoid.PlatformStand = oldPlatformStand
    rootPart.AssemblyLinearVelocity  = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero
    rootPart.Anchored = false
    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
end


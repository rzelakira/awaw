local function tableContains(list, value)
    if not list then return false end
    for _, v in ipairs(list) do
        if v == value then return true end
    end
    return false
end

local function formatNumber(n)
    if not n then return "0" end
    local num = tonumber(n) or 0
    if num >= 1e15 then
        local v = num / 1e15
        return v % 1 == 0 and string.format("%.0fQ", v) or string.format("%.2fQ", v)
    elseif num >= 1e12 then
        local v = num / 1e12
        return v % 1 == 0 and string.format("%.0fT", v) or string.format("%.2fT", v)
    elseif num >= 1e9 then
        local v = num / 1e9
        return v % 1 == 0 and string.format("%.0fB", v) or string.format("%.2fB", v)
    elseif num >= 1e6 then
        local v = num / 1e6
        return v % 1 == 0 and string.format("%.0fM", v) or string.format("%.2fM", v)
    elseif num < 1000 then
        return tostring(math.floor(num))
    end
    local v = num / 1000
    return v % 1 == 0 and string.format("%.0fK", v) or string.format("%.2fK", v)
end

local function getPetsInfoText()
    local grouped = {}
    for _, pet in ipairs(State.PetsFolder:GetChildren()) do
        local t = pet:GetAttribute("T") or "Unknown"
        local m = pet:GetAttribute("M") or "Normal"
        local key = t .. "_" .. m
        if not grouped[key] then
            grouped[key] = { type = t, mutation = m, count = 0 }
        end
        grouped[key].count = grouped[key].count + 1
    end

    if next(grouped) == nil then
        return "No pets found in inventory"
    end

    local list = {}
    for _, entry in pairs(grouped) do
        table.insert(list, entry)
    end
    table.sort(list, function(a, b) return a.type < b.type end)

    local text = ""
    for _, entry in ipairs(list) do
        text = text .. string.format("[%s] %s = %d\n", entry.mutation, entry.type, entry.count)
    end
    return text
end


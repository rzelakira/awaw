end)()

local function estimateProduce(t, m, m2)
    local baseData = ResPetCfg[t]
    local base = (baseData and baseData.ProduceRate) or 0
    local mult = 0
    if m and m ~= "None" and ResMutateCfg[m] then
        mult = mult + (ResMutateCfg[m].ProduceRate or 0)
    end
    if m2 and ResMutateCfg[m2] then
        mult = mult + (ResMutateCfg[m2].ProduceRate or 0)
    end
    if mult == 0 then mult = 1 end
    return base * mult
end

local function isOceanPet(t)
    local d = ResPetCfg[t]
    return d ~= nil and (d.Category == "Ocean" or d.Sheet == "Ocean")
end

local function getEmptyCells(isOcean)
    local cells = {}
    local islandName = State.LocalPlayer:GetAttribute("AssignedIslandName")
    local island = islandName and workspace:FindFirstChild("Art") and workspace.Art:FindFirstChild(islandName)
    if not island then return cells end

    local occupied = {}
    local petsWorkspace = workspace:FindFirstChild("Pets")
    if petsWorkspace then
        for _, pt in ipairs(petsWorkspace:GetChildren()) do
            if pt:GetAttribute("UserId") == State.LocalPlayer.UserId then
                local g = pt:GetAttribute("GridCenterPos")
                if g then
                    occupied[math.floor(g.X + 0.5) .. "," .. math.floor(g.Z + 0.5)] = true
                end
            end
        end
    end

    for _, d in ipairs(island:GetDescendants()) do
        if d:IsA("BasePart") then
            local name = d.Name
            local isWaterTile = string.find(name, "WaterFarm_split") ~= nil
            local isLandTile  = (not isWaterTile) and string.find(name, "Farm_split") ~= nil
            local match = (isOcean and isWaterTile) or ((not isOcean) and isLandTile)
            if match then
                local pos = d.Position
                local key = math.floor(pos.X + 0.5) .. "," .. math.floor(pos.Z + 0.5)
                if not occupied[key] then
                    table.insert(cells, { x = pos.X, y = pos.Y + d.Size.Y * 0.5, z = pos.Z })
                end
            end
        end
    end
    return cells
end

local function autoPlacePets()
    if State.PlacingActive then return end
    if not fireproximityprompt then
        Notify("Auto Place", "Executor tidak support fireproximityprompt", 4)
        return
    end

    local petsWorkspace = workspace:FindFirstChild("Pets")
    if not petsWorkspace then
        Notify("Auto Place", "Pets folder not found", 3)
        return
    end
    local ppart = workspace:FindFirstChild("PPart")
    local prompt = ppart and ppart:FindFirstChildWhichIsA("ProximityPrompt")
    if not prompt then
        Notify("Auto Place", "PPart prompt not found", 3)
        return
    end

    local filter    = _G.BuildAZooSettings.Place.Filter
    local threshold = tonumber(_G.BuildAZooSettings.Place.Threshold) or 0

    local candidates = {}
    for _, pet in ipairs(State.PetsFolder:GetChildren()) do
        if not petsWorkspace:FindFirstChild(pet.Name) and not pet:GetAttribute("BPV") then
            local t = pet:GetAttribute("T")
            local est = estimateProduce(t, pet:GetAttribute("M"), pet:GetAttribute("M2"))
            local pass = (filter == "Above" and est >= threshold) or (filter == "Below" and est <= threshold)
            if pass then
                table.insert(candidates, { uid = pet.Name, est = est, ocean = isOceanPet(t) })
            end
        end
    end

    if #candidates == 0 then
        Notify("Auto Place", "Tidak ada pet yang cocok filter", 3)
        return
    end
    table.sort(candidates, function(a, b) return a.est > b.est end)

    State.PlacingActive = true
    State.PlaceThread = task.spawn(function()
        local char = State.LocalPlayer.Character or State.LocalPlayer.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local origCF = hrp.CFrame
        local placed = 0

        for _, cand in ipairs(candidates) do
            if not State.PlacingActive then break end
            if petsWorkspace:FindFirstChild(cand.uid) then
                placed = placed + 1
            else
                local cells = getEmptyCells(cand.ocean)
                if #cells == 0 then
                    Notify("Auto Place", (cand.ocean and "Petak air" or "Petak darat") .. " penuh, lanjut pet lain", 3)
                end

                local ok = false
                local attempts = math.min(#cells, 6)
                for i = 1, attempts do
                    if not State.PlacingActive then break end

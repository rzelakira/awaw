local function onTradeEvent(data)
    if not (_G.BuildAZooSettings.Pets.AutoTradePet and State.IsProcessingTrade) then return end
    if not (data.event == "reqtrade" and data.data) then return end

    local bargainRate = data.data.BargainRate or 0
    task.wait(1)

    if bargainRate < 0.2 then
        pcall(function()
            Remote("TradeRE"):FireServer({ event = "accept" })
        end)
        Notify("Auto Trade", string.format("Trade Accepted! Rate: %.3f", bargainRate), 3)
        State.IsProcessingTrade = true
        task.wait(2)
        State.IsProcessingTrade = false
    else
        pcall(function()
            Remote("TradeRE"):FireServer({ event = "decline" })
        end)
        Notify("Auto Trade", string.format("Trade Declined! Rate: %.3f", bargainRate), 3)
        State.IsProcessingTrade = false
    end
end


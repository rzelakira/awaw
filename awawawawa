    if State.AutoTradePetThread then
        _G.BuildAZooSettings.Pets.AutoTradePet = false
        task.wait(0.5)
        pcall(task.cancel, State.AutoTradePetThread)
        State.AutoTradePetThread = nil
    end

    State.CurrentTradePetUID = nil
    State.IsProcessingTrade  = false

    if not State.TradeEventConnection then
        State.TradeEventConnection = Remote("TradeRE").OnClientEvent:Connect(onTradeEvent)
    end

    State.AutoTradePetThread = task.spawn(function()
        while _G.BuildAZooSettings.Pets.AutoTradePet do

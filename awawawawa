function AutoClaimCoins()
    if not _G.BuildAZooSettings.Main.AutoClaimCoins then return end

    local petsFolder = workspace:FindFirstChild("Pets")
    if not petsFolder then return end

    local rootPart = (State.LocalPlayer.Character or State.LocalPlayer.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    local userId = State.LocalPlayer.UserId

    local coins = {}
    for _, part in ipairs(petsFolder:GetChildren()) do
        if part:IsA("BasePart") and part:GetAttribute("UserId") == userId and not State._ClaimVisited[part] then
            local cf = part.CFrame
            table.insert(coins, {
                pet  = part,
                cf   = cf,
                dist = (rootPart.Position - cf.Position).Magnitude,
            })
        end
    end

    if #coins == 0 then
        State._ClaimVisited = {}
        return
    end

    local pos    = rootPart.Position
    local lookV  = rootPart.CFrame.LookVector
    local rightV = rootPart.CFrame.RightVector

    local frontBack, left, right = {}, {}, {}
    for _, coin in ipairs(coins) do
        local dir  = (coin.cf.Position - pos).Unit
        local dotF = lookV:Dot(dir)
        local dotR = rightV:Dot(dir)
        if math.abs(dotF) >= 0.5 then
            table.insert(frontBack, coin)
        elseif dotR > 0 then
            table.insert(right, coin)
        else
            table.insert(left, coin)
        end
    end

    local byDist = function(a, b) return a.dist < b.dist end
    table.sort(left, byDist)
    table.sort(right, byDist)
    table.sort(frontBack, byDist)

    local ordered = {}
    for _, c in ipairs(left)      do table.insert(ordered, c) end
    for _, c in ipairs(right)     do table.insert(ordered, c) end
    for _, c in ipairs(frontBack) do table.insert(ordered, c) end

    local target = ordered[1]
    local targetPos = target.cf.Position
    local goalCF = CFrame.new(targetPos.X, rootPart.Position.Y, targetPos.Z)

    if _G.BuildAZooSettings.Main.CoinMoveMethod == "Teleport" then
        rootPart.CFrame = goalCF
    elseif _G.BuildAZooSettings.Main.CoinMoveMethod == "Tween" then
        local tween = State.TweenService:Create(rootPart, TweenInfo.new(0.05, Enum.EasingStyle.Linear), { CFrame = goalCF })
        tween:Play()
        tween.Completed:Wait()
    end

    State._ClaimVisited[target.pet] = true
end

local function doFishing()
    local remoteFolder = ReplicatedStorage:FindFirstChild("Remote")
    if not remoteFolder then return end

    local characterRE = remoteFolder:FindFirstChild("CharacterRE")
    local fishingRE   = remoteFolder:FindFirstChild("FishingRE")
    if not (characterRE and fishingRE) then return end

    characterRE:FireServer("Focus", "FishRob")
    task.wait(0.5)
    fishingRE:FireServer("Start")
    task.wait(0.5)
    fishingRE:FireServer("Throw", {
        Bait = _G.BuildAZooSettings.Main.FishBait,
        Pos  = _G.BuildAZooSettings.Main.FishingPos.Position,
    })
    task.wait(0.5)
    fishingRE:FireServer("POUT", { SUC = 1 })
end


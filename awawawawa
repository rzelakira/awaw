        Title   = title or "WisHUB",
        Content = content or "",
        Delay   = delay or 3,
    })
end

local function AddSection(tab, title, open)
    local section = tab:AddSection(title, open)
    local rawAddDropdown = section.AddDropdown
    function section:AddDropdown(cfg)
        if type(cfg) == "table" and cfg.Multi ~= true and type(cfg.Callback) == "function" then
            local callback = cfg.Callback
            cfg.Callback = function(value)
                if type(value) == "table" then
                    return callback(value[1])
                end
                return callback(value)
            end
        end
        return rawAddDropdown(self, cfg)
    end
    return section
end

